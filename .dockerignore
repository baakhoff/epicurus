# Keep the Docker build context lean.
.git
.github
.venv
**/.venv
**/__pycache__
**/*.py[cod]
.mypy_cache
.pytest_cache
.ruff_cache
.workspace
# `docs/` is intentionally NOT ignored: the knowledge module bundles it into its
# image (`COPY docs/ /docs`) for self-documentation (#83). It only lands in the
# knowledge image — no other service COPYs it from the context.
site
backups
data
storage
volumes
*.log

# Frontend (services/web) — never ship node_modules or local builds in a context.
**/node_modules
**/dist
