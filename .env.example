# Copy to `.env` and fill in. NEVER commit `.env` (it is gitignored).
#
# Real secrets (API keys, OAuth client secrets, tokens) do NOT belong here —
# they live in OpenBao and are fetched at runtime. This file is only for
# non-secret, machine-local configuration and pointers.

# Environment name: local | staging | production
APP_ENV=local

# Log verbosity: debug | info | warning | error
LOG_LEVEL=info

# Default tenant for local / self-host. Tenant is a first-class primitive even
# at a single tenant (the dual-track rule). Multi-tenant deployments resolve this
# per request instead of from a static default.
DEFAULT_TENANT_ID=local

# NATS event backbone. On the internal Docker network use nats://nats:4222.
# The module<->core contract is local-only.
NATS_URL=nats://localhost:4222

# OpenBao (secrets). On the internal Docker network use http://openbao:8200.
# The token is the bootstrap secret — inject it at runtime, never commit it.
OPENBAO_URL=http://localhost:8200
# OPENBAO_TOKEN=

# ── Host bind address ────────────────────────────────────────────────────────
# Published container ports bind to this address. The default 127.0.0.1 keeps
# every service reachable only from this machine (private by default).
# Set 0.0.0.0 (or a specific interface IP) to expose the stack beyond it — and
# put your own perimeter (VPN / reverse proxy / auth proxy) in front when you do.
# BIND_ADDRESS=127.0.0.1

# ── Host ports & dev credentials (FULL STACK) ───────────────────────────────
# `docker compose up` from the repo root reads THIS file and assembles the whole
# stack (data plane + edge + observability + modules). Everything has a safe
# default — uncomment only what you want to change. (The standalone data-plane
# stack, `docker compose -f infra/compose/docker-compose.yml`, reads
# infra/compose/.env instead — see infra/compose/.env.example.)
#
# Data plane
# POSTGRES_PORT=5432
# VALKEY_PORT=6379
# NATS_PORT=4222
# NATS_MONITOR_PORT=8222
# QDRANT_HTTP_PORT=6333
# QDRANT_GRPC_PORT=6334
# OPENBAO_PORT=8200
# Edge gateway
# EDGE_HTTP_PORT=8088
# EDGE_DASHBOARD_PORT=8089
# Observability
# GRAFANA_PORT=3000
# PROMETHEUS_PORT=9090
# LOKI_PORT=3100
# OTLP_GRPC_PORT=4317
# OTLP_HTTP_PORT=4318
# Modules
# ECHO_PORT=8080
# CORE_PORT=8082
#
# Dev-only data-plane credentials (weak on purpose; local private box only):
# POSTGRES_USER=epicurus
# POSTGRES_PASSWORD=epicurus-dev
# POSTGRES_DB=epicurus
# OPENBAO_DEV_ROOT_TOKEN=dev-root-token
