# Copy to `.env` and fill in. NEVER commit `.env` (it is gitignored).
#
# Real secrets (API keys, OAuth client secrets, tokens) do NOT belong here —
# they live in OpenBao and are fetched at runtime. This file is only for
# non-secret, machine-local configuration and pointers.

# Environment name: local | staging | production
APP_ENV=local

# Log verbosity: debug | info | warning | error
LOG_LEVEL=info

# Default tenant for local / self-host. Tenant is a first-class primitive even
# at a single tenant (dual-track rule — see docs/DUAL-TRACK.md). Multi-tenant
# SaaS resolves this per request instead of from a static default.
DEFAULT_TENANT_ID=local
