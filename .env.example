# Copy to `.env` and fill in. NEVER commit `.env` (it is gitignored).
#
# Real secrets (API keys, OAuth client secrets, tokens) do NOT belong here —
# they live in OpenBao and are fetched at runtime. This file is only for
# non-secret, machine-local configuration and pointers.

# Environment name: local | staging | production
APP_ENV=local

# ── Image tag pinning (#56) ──────────────────────────────────────────────────
# All service compose fragments default to `${EPICURUS_VERSION:-latest}`.
# Omitting this var (the default) pulls :latest — convenient for local dev
# where you always want the most recent build.
# For staging / production, pin to the exact stack release being deployed so
# every `docker compose up` is reproducible and the same image moves unchanged
# through staging → prod (the immutable-image principle in DEPLOYMENT.md).
# EPICURUS_VERSION=0.1.0

# Log verbosity: debug | info | warning | error
LOG_LEVEL=info

# Default tenant for local / self-host. Tenant is a first-class primitive even
# at a single tenant (the dual-track rule). Multi-tenant deployments resolve this
# per request instead of from a static default.
DEFAULT_TENANT_ID=local

# NATS event backbone. On the internal Docker network use nats://nats:4222.
# The module<->core contract is local-only.
NATS_URL=nats://localhost:4222

# OpenBao (secrets). On the internal Docker network use http://openbao:8200.
# OPENBAO_UNSEAL_KEY and OPENBAO_TOKEN are generated by the bootstrap script
# (infra/compose/scripts/openbao-bootstrap.sh) and written to
# infra/compose/.env.secrets (gitignored). Copy them here after first run.
OPENBAO_URL=http://localhost:8200
# OPENBAO_UNSEAL_KEY=   # Shamir unseal key — auto-unseals the vault on restart
# OPENBAO_TOKEN=        # app token for core-app (non-expiring, epicurus-core policy)

# OAuth connect flow (#86). OAUTH_STATE_SECRET is REQUIRED before using any OAuth
# flow — it signs the state token (the CSRF defense), and the flow refuses to run
# while it is unset or the placeholder. Generate: `openssl rand -hex 32`.
# OAUTH_STATE_SECRET=
# Public base URL the provider redirects back to (must match the registered URI):
# OAUTH_REDIRECT_BASE_URL=http://localhost:8084

# ── LLM gateway tuning (core-app, #114) ──────────────────────────────────────
# All optional — leave unset to use the model/runtime defaults. Changing any of
# these needs only a restart, never a code edit.
# LLM_DEFAULT_MODEL=llama3.2   # model used when a request names none
# LLM_KEEP_ALIVE=5m            # how long Ollama keeps a model loaded (ADR-0005)
# LLM_FALLBACKS=               # comma-separated fallback chain, e.g. claude/claude-3-5-sonnet-latest
# LLM_NUM_RETRIES=2            # per-model retries on 429/5xx (LiteLLM backoff)
# LLM_TEMPERATURE=             # sampling temperature (local + hosted)
# LLM_TOP_P=                   # nucleus-sampling top_p (local + hosted)
# LLM_NUM_CTX=                 # Ollama context window (num_ctx); local models only
# LLM_CATALOG_URL=https://ollama.com/library  # source the model browser is parsed from (#269)
# LLM_CATALOG_REFRESH_SECONDS=21600           # how often the catalog re-parses (default 6h)
# LLM_CATALOG_MAX_MODELS=0                     # cap on model families (0 = unlimited)
# LLM_CATALOG_ENABLED=true                     # false = serve the built-in seed, no outbound fetch

# ── OpenTelemetry tracing (#57) ──────────────────────────────────────────────
# The observability stack's third signal. OFF by default — the lean stack pays
# nothing, and disabled tracing is a runtime no-op (no exporter, no spans). Turn it
# on fleet-wide (every service reads these): set OTEL_TRACES_ENABLED=true AND bring
# the stack up with the observability profile so Tempo is listening:
#   OTEL_TRACES_ENABLED=true docker compose --profile observability up -d
# Then explore traces in Grafana (Tempo datasource). The endpoint is the OTLP/HTTP
# base — the exporter appends /v1/traces — on the internal Docker network.
# OTEL_TRACES_ENABLED=false
# OTEL_EXPORTER_OTLP_ENDPOINT=http://tempo:4318

# ── Shared file space (#KB-refactor) ─────────────────────────────────────────
# One tree where every file-owning module writes its own top-level folder. The on-disk
# layout is TENANT-SCOPED (constraint #1): the modules write under <tenant>/, i.e.
# <root>/<tenant>/knowledge/ (each subfolder is a "project"/knowledge base) and
# <root>/<tenant>/notes/, where <tenant> is DEFAULT_TENANT_ID (default "local"). The
# storage module indexes <root>/<tenant> read-only as the unified "Files" view (you can
# browse and read those .md files there). Default is an empty named volume (epicurus-files);
# set this to an ABSOLUTE host path to expose real files on disk. Replaces the old
# per-module KNOWLEDGE_HOST_VAULT and STORAGE_HOST_ROOT. files-init creates the
# <tenant>/{knowledge,notes} subfolders and makes them writable by the service user
# (uid 10001) on first start.
# EPICURUS_FILES_ROOT=/absolute/path/to/your/files

# ── Host bind address ────────────────────────────────────────────────────────
# Published container ports bind to this address. The default 127.0.0.1 keeps
# every service reachable only from this machine (private by default).
# Set 0.0.0.0 (or a specific interface IP) to expose the stack beyond it — and
# put your own perimeter (VPN / reverse proxy / auth proxy) in front when you do.
# BIND_ADDRESS=127.0.0.1

# ── Host ports & dev credentials (FULL STACK) ───────────────────────────────
# `docker compose up` from the repo root reads THIS file and assembles the whole
# stack (data plane + edge + observability + modules). Everything has a safe
# default — uncomment only what you want to change. (The standalone data-plane
# stack, `docker compose -f infra/compose/docker-compose.yml`, reads
# infra/compose/.env instead — see infra/compose/.env.example.)
#
# Data plane
# POSTGRES_PORT=5432
# VALKEY_PORT=6379
# NATS_PORT=4222
# NATS_MONITOR_PORT=8222
# QDRANT_HTTP_PORT=6333
# QDRANT_GRPC_PORT=6334
# OPENBAO_PORT=8200
# Edge gateway
# EDGE_HTTP_PORT=8088
# EDGE_DASHBOARD_PORT=8089
# Observability
# GRAFANA_PORT=3000
# PROMETHEUS_PORT=9090
# LOKI_PORT=3100
# OTLP_GRPC_PORT=4317
# OTLP_HTTP_PORT=4318
# Modules
# ECHO_PORT=8080
# CORE_PORT=8082
# WEB_PORT=8084
#
# Dev-only data-plane credentials (weak on purpose; local private box only):
# POSTGRES_USER=epicurus
# POSTGRES_PASSWORD=epicurus-dev
# POSTGRES_DB=epicurus

# ── Auto-deploy / Watchtower (infra/cd/watchtower.yaml) ─────────────────────
# Only needed if you run the optional Watchtower fragment for automatic
# image tracking.  Create a GitHub PAT with `read:packages` scope.
# GHCR_USERNAME=
# GHCR_TOKEN=
