# ─── Data, models, storage (large / private / machine-local) ────────────────
# Anchored to the repo root: unanchored `storage/` etc. would silently ignore
# real source directories like services/storage/ or a models/ package.
/data/
/storage/
/volumes/
*.db
*.sqlite
*.sqlite3
/models/
*.gguf
*.bin
*.safetensors
*.pt
*.onnx
/vector-store/
/backups/

# ─── Docker / runtime ────────────────────────────────────────────────────────
docker-compose.override.yml
*.local.yml

# ─── Logs ────────────────────────────────────────────────────────────────────
/logs/
*.log

