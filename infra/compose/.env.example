# Copy to `infra/compose/.env` (gitignored) to override the data-plane defaults.
# These are LOCAL DEV defaults for a private box; how the deployment is exposed
# is the operator's choice (ADR-0008). Real staging/prod credentials are
# injected from OpenBao, never from this file.

# Bind address for published ports: 127.0.0.1 keeps services reachable only
# from this machine. Set 0.0.0.0 (or an interface IP) to expose them deliberately.
BIND_ADDRESS=127.0.0.1

# Postgres
POSTGRES_USER=epicurus
POSTGRES_PASSWORD=epicurus-dev
POSTGRES_DB=epicurus
POSTGRES_PORT=5432

# Valkey
VALKEY_PORT=6379

# NATS — authenticated bus (#50, ADR-0066). One password per role: `core` (full bus),
# `module` (tenant-scoped subjects), `sys` (monitoring). These weak dev defaults are
# for a private box; openbao-bootstrap.sh generates strong ones. The same value must
# reach the nats server AND every service (compose maps it to both sides).
NATS_PORT=4222
NATS_MONITOR_PORT=8222
NATS_CORE_PASSWORD=epicurus-dev
NATS_MODULE_PASSWORD=epicurus-dev
NATS_SYS_PASSWORD=epicurus-dev

# Qdrant
# Single source of truth for the qdrant server image tag AND the qdrant-init version
# marker. Bump this (in lockstep with the qdrant-client pin) to upgrade; the qdrant-init
# guard resets the (derived, re-indexable) store if the on-disk format changed. See
# docs/infrastructure/qdrant.md.
QDRANT_TAG=v1.18.2
QDRANT_HTTP_PORT=6333
QDRANT_GRPC_PORT=6334

# OpenBao (dev mode: IN-MEMORY — a container restart wipes stored secrets;
# the root token is dev-only)
OPENBAO_DEV_ROOT_TOKEN=dev-root-token
OPENBAO_PORT=8200

# MinIO — S3-compatible object store for app-managed objects.
# Dev credentials only; Phase 3 wires OpenBao as the live credential source.
# MINIO_ROOT_USER and MINIO_ROOT_PASSWORD act as the S3 access key / secret key.
MINIO_ROOT_USER=epicurus
MINIO_ROOT_PASSWORD=epicurus-dev
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_DEFAULT_BUCKET=epicurus
