# Copy to `infra/compose/.env` (gitignored) to override the data-plane defaults.
# These are LOCAL DEV defaults for a Tailscale-only box. Real staging/prod
# credentials are injected from OpenBao, never from this file.

# Postgres
POSTGRES_USER=epicurus
POSTGRES_PASSWORD=epicurus-dev
POSTGRES_DB=epicurus
POSTGRES_PORT=5432

# Valkey
VALKEY_PORT=6379

# NATS
NATS_PORT=4222
NATS_MONITOR_PORT=8222

# Qdrant
QDRANT_HTTP_PORT=6333
QDRANT_GRPC_PORT=6334

# OpenBao (dev mode; root token is dev-only)
OPENBAO_DEV_ROOT_TOKEN=dev-root-token
OPENBAO_PORT=8200
