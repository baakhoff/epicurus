{
  "compilerOptions": {
    "target": "ES2022",
    "useDefineForClassFields": true,
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "types": ["vite/client", "vite-plugin-pwa/client"],
    "skipLibCheck": true,

    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "moduleDetection": "force",
    "noEmit": true,
    "jsx": "react-jsx",

    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedSideEffectImports": true,

    // TS 6 deprecates `baseUrl` (still resolves `paths`); silence until TS 7 removes it.
    "ignoreDeprecations": "6.0",
    "baseUrl": ".",
    "paths": { "@/*": ["src/*"] }
  },
  "include": ["src", "vite.config.ts", "eslint.config.js", "scripts"],
  // A service worker's global scope (ServiceWorkerGlobalScope) can't coexist with this
  // project's "DOM" lib in one tsconfig — see src/sw.ts's own top comment (#493). Vite still
  // bundles it via the injectManifest strategy regardless; that's wired independently in
  // vite.config.ts, not through this file's `include`.
  "exclude": ["src/sw.ts"]
}
